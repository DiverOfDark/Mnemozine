# Mnemozine configuration — copy to .env and adjust.
# Every variable here maps to a field in mnemozine/config.py (Settings).
# Nested sections use the `__` delimiter; prefix is MNEMOZINE_.

# --- FalkorDB (single store: graph + vectors, FR-STO-2) ---
MNEMOZINE_FALKORDB__URL=redis://localhost:6379
MNEMOZINE_FALKORDB__GRAPH_NAME=mnemozine
# MNEMOZINE_FALKORDB__PASSWORD=

# --- Extraction LLM (pluggable OpenAI-format base_url; default local Qwen, §5.5) ---
MNEMOZINE_EXTRACTION__BASE_URL=http://localhost:8000/v1
MNEMOZINE_EXTRACTION__MODEL=openai/qwen2.5
MNEMOZINE_EXTRACTION__API_KEY=not-needed
MNEMOZINE_EXTRACTION__TEMPERATURE=0.0
MNEMOZINE_EXTRACTION__TIMEOUT_S=120

# --- Embeddings (bge-m3 via Ollama, self-hosted, OQ3) ---
MNEMOZINE_EMBEDDING__BASE_URL=http://localhost:11434
MNEMOZINE_EMBEDDING__MODEL=bge-m3
MNEMOZINE_EMBEDDING__DIMENSIONS=1024
MNEMOZINE_EMBEDDING__TIMEOUT_S=60

# --- Injection budget (FR-RET-3/5) ---
MNEMOZINE_INJECT__TOKEN_BUDGET=500
MNEMOZINE_INJECT__MAX_PREFERENCE_SNIPPETS=5

# --- Cross-reference engine (FR-RET-6, §6.6) ---
MNEMOZINE_CROSSREF__RELEVANCE_THRESHOLD=0.8
MNEMOZINE_CROSSREF__MAX_SUGGESTIONS=2
# Vector-similarity fallback gate (distinct from RELEVANCE_THRESHOLD, FR-RET-6).
MNEMOZINE_CROSSREF__VECTOR_FALLBACK_THRESHOLD=0.75

# --- Maintenance / dedup / decay (FR-MNT-*, §6.6) ---
MNEMOZINE_MAINTENANCE__DEDUP_EQUIVALENCE_THRESHOLD=0.9
MNEMOZINE_MAINTENANCE__EDGE_WEIGHT_FLOOR=0.1
MNEMOZINE_MAINTENANCE__MAX_NODE_DEGREE=64
# FR-MNT-1 contradiction-candidate cap fed to the cheap supersede LLM call.
MNEMOZINE_MAINTENANCE__CONTRADICTION_CANDIDATE_CAP=5
MNEMOZINE_MAINTENANCE__DECAY_HALF_LIFE_DAYS=30
MNEMOZINE_MAINTENANCE__DECAY_ARCHIVE_AFTER_DAYS=90
MNEMOZINE_MAINTENANCE__CRON=0 3 * * *

# --- Ingestion / chunking (FR-ING-*, §6.6) ---
MNEMOZINE_INGEST__CHUNK_MAX_CHARS=8000
MNEMOZINE_INGEST__CHUNK_MAX_MESSAGES=40
# CLAUDE_CONFIG_DIR — root of Claude Code config/transcripts (FR-ING-2).
MNEMOZINE_INGEST__CLAUDE_CONFIG_DIR=~/.claude
# Claude Code transcript retention before local cleanup (FR-ING-2/R4).
MNEMOZINE_INGEST__CLEANUP_PERIOD_DAYS=30
MNEMOZINE_INGEST__STRIP_TOOL_CALLS=true

# --- Retrieval (FR-RET-2, §6.6) ---
MNEMOZINE_RETRIEVAL__P95_LATENCY_TARGET_MS=500
MNEMOZINE_RETRIEVAL__TOP_K=10
# Entity-neighborhood traversal depth (hops) for scoped retrieve (FR-RET-2).
MNEMOZINE_RETRIEVAL__NEIGHBORHOOD_HOPS=1

# --- MCP server (FR-RET-1) ---
MNEMOZINE_MCP_HOST=127.0.0.1
MNEMOZINE_MCP_PORT=8765

# --- Misc ---
MNEMOZINE_LOG_LEVEL=INFO

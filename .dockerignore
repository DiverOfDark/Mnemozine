# Keep the build context small and reproducible. The Dockerfile needs
# pyproject.toml, README.md, the mnemozine/ package, and web/ (SPA source).
.git
.gitignore
.venv
venv
env
ENV
**/__pycache__
*.py[cod]
*.egg-info
build
dist
.eggs
wheels

# caches
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
.coverage.*
htmlcov

# editors / tooling
.idea
.vscode
*.swp
.DS_Store

# local secrets & data — never bake into the image
.env
.env.*
!.env.example
data
archive
*.log

# tests are not needed at runtime
tests

# deploy artifacts (avoid recursive context)
deploy

# frontend build artifacts — the SPA is built fresh in the node stage; keep the
# web/ source in context but never ship local installs/builds.
web/node_modules
web/dist
mnemozine/web/static
docs/webui-screenshots
